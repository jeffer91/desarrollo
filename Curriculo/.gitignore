# =========================================================
# .gitignore
# Proyecto: Curriculo
# Ubicación: /Curriculo/.gitignore
# Función:
# - Evitar subir archivos locales, temporales o innecesarios
# - Mantener limpio el repositorio de GitHub
# =========================================================

# Configuración local de editores
.vscode/
.idea/

# Dependencias
node_modules/

# Archivos de entorno / secretos
.env
.env.*
!.env.example

# Builds / compilados
dist/
build/
out/
release/
www/

# Cachés
.cache/
.parcel-cache/
.vite/
.next/
.nuxt/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Temporales del sistema
.DS_Store
Thumbs.db
desktop.ini

# Temporales de editores
*.tmp
*.temp
*.swp
*.swo
*~

# Backups locales
*.bak
*.backup
*.old
*.orig

# Exportaciones locales o descargas temporales
exports/
exportaciones/
downloads/
descargas/

# Archivos comprimidos generados manualmente
*.zip
*.rar
*.7z

# Firebase local / emuladores
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# Cobertura o pruebas
coverage/

# Electron / empaquetado
*.asar
*.blockmap

# Android / APK local
android/.gradle/
android/app/build/
*.apk
*.aab
