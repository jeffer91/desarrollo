{
  "appId": "com.jeff.desarrollo.shell",
  "productName": "Desarrollo",
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "asar": false,
  "compression": "normal",
  "electronUpdaterCompatibility": ">=2.16",
  "directories": {
    "output": "dist",
    "buildResources": "build"
  },
  "files": [
    {
      "from": "..",
      "to": ".",
      "filter": [
        "index.html",
        "package.json",
        "app/**/*",
        "audit/**/*",
        "Curriculo/**/*",
        "Docentes/**/*",
        "Documentos/**/*",
        "eventos/**/*",
        "incorporaciones/**/*",
        "localsave/**/*",
        "txt-exporter-electron/package.json",
        "txt-exporter-electron/src/**/*",
        "!**/node_modules/**",
        "!**/.git/**",
        "!**/dist/**",
        "!**/build/**",
        "!**/txt_convertidos/**"
      ]
    },
    {
      "from": ".",
      "to": ".",
      "filter": [
        "package.json"
      ]
    },
    {
      "from": ".",
      "to": "electron",
      "filter": [
        "main.js",
        "preload.js",
        "updater.js",
        "eventos-background-manager.js"
      ]
    }
  ],
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "jeffer91",
      "repo": "desarrollo",
      "releaseType": "release"
    }
  ],
  "win": {
    "icon": "build/icon.ico",
    "requestedExecutionLevel": "asInvoker",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "portable": {
    "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
  },
  "nsis": {
    "oneClick": true,
    "allowToChangeInstallationDirectory": false,
    "perMachine": false,
    "allowElevation": false,
    "deleteAppDataOnUninstall": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Desarrollo",
    "runAfterFinish": true,
    "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
  }
}
