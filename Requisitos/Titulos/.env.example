# Nombre completo: .env.example
# Ruta o ubicación: /Requisitos/Titulos/.env.example
# Función o funciones:
# - Servir como plantilla de variables de entorno para Netlify, Firebase y Telegram.
# - Evitar que claves privadas se escriban directamente en el código público.
# - Separar configuración pública de Firebase y configuración privada del servidor.
# Se conecta con:
# - src/firebase/ta-titulo-articulo-firebase-client.js
# - netlify/functions/ta-titulo-articulo-api-telegram.js
# - netlify/functions/ta-titulo-articulo-api-security.js

# =========================================================
# Firebase público para frontend
# Estos valores permiten conectar la app web con Firebase.
# La seguridad real se manejará con Firestore Rules y Netlify Functions.
# =========================================================
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# =========================================================
# Firebase Admin para Netlify Functions
# Nunca colocar estos valores dentro del frontend.
# =========================================================
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""

# =========================================================
# Telegram privado
# El token del bot nunca debe ir en archivos públicos.
# =========================================================
TELEGRAM_BOT_TOKEN=""

# =========================================================
# Seguridad interna básica para funciones privadas
# Se usará en funciones administrativas desde Electron.
# =========================================================
TA_TITULO_ARTICULO_ADMIN_TOKEN=""
