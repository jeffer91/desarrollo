# Nombre completo: .env.example
# Ruta o ubicación: /Requisitos/Titulos/.env.example
# Función o funciones:
# - Servir como plantilla de variables de entorno para Netlify, Firebase y Telegram.
# - Evitar que claves privadas se escriban directamente en el código público.
# - Separar configuración pública de Firebase y configuración privada del servidor.
# - Documentar variables obligatorias antes del despliegue final en Netlify.
# Se conecta con:
# - src/firebase/ta-titulo-articulo-firebase-client.js
# - netlify/functions/ta-titulo-articulo-api-security.js
# - netlify/functions/ta-titulo-articulo-api-telegram.js

# =========================================================
# NETLIFY
# Base directory recomendada en Netlify: Requisitos/Titulos
# Build command: npm run build:netlify
# Publish directory: dist
# Functions directory: netlify/functions
# =========================================================

# =========================================================
# Firebase público para frontend local/Vite
# Estos valores no deben confundirse con Firebase Admin.
# Si se dejan vacíos en local, la app usa la configuración pública por defecto del proyecto utet-4387a.
# =========================================================
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# =========================================================
# Firebase Admin para Netlify Functions
# OBLIGATORIO en Netlify.
# FIREBASE_ADMIN_PRIVATE_KEY debe conservar los saltos como \n si se pega en una sola línea.
# Nunca colocar estos valores dentro del frontend.
# =========================================================
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# =========================================================
# Seguridad interna para funciones administrativas
# OBLIGATORIO si se usan funciones admin/telegram.
# Debe ser una cadena larga y difícil de adivinar.
# =========================================================
TA_TITULO_ARTICULO_ADMIN_TOKEN=""

# =========================================================
# Telegram privado
# Obligatorio solo si se enviarán avisos por Telegram desde Netlify Functions.
# El token del bot nunca debe ir en archivos públicos.
# =========================================================
TELEGRAM_BOT_TOKEN=""
