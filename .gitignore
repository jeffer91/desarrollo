# =========================================================
# Nombre completo: .gitignore
# Ruta o ubicación: /.gitignore
# Función:
# - Evitar subir dependencias, compilados y archivos sensibles.
# - NO bloquear carpetas de código fuente del proyecto.
# =========================================================

# =========================================================
# Dependencias
# =========================================================
node_modules/
**/node_modules/

# =========================================================
# Logs y temporales
# =========================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
tmp/
temp/
.cache/

# =========================================================
# Archivos del sistema
# =========================================================
.DS_Store
Thumbs.db

# =========================================================
# Visual Studio Code
# Se permite subir la configuración base del proyecto.
# =========================================================
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# =========================================================
# Variables de entorno y credenciales
# =========================================================
.env
.env.*
**/.env
**/.env.*
*.pem
*.key
serviceAccount*.json
*service-account*.json
*firebase-adminsdk*.json
*credentials*.json
*secret*.json

# =========================================================
# Compilados / instaladores / empaquetados
# Estos archivos se generan de nuevo y no son código fuente.
# =========================================================
dist/
build/
out/
release/
*.blockmap
*.exe
*.dmg
*.AppImage
*.zip
*.7z
*.rar

# =========================================================
# Exportaciones o datos locales generados por la app
# =========================================================
txt_convertidos/
localsave/data/*.json
localsave/backups/
localsave/temp/

# =========================================================
# IMPORTANTE:
# No se ignoran carpetas de código como:
# app/, electron/, eventos/, Requisitos/, Documentos/, Docentes/,
# incorporaciones/, Curriculo/, localsave/.
# =========================================================
